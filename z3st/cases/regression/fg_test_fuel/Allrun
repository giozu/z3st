#!/bin/bash
cd "${0%/*}" || exit 1

export SCIANTIX_LIB="${SCIANTIX_LIB:-/tmp/libsciantix_tu.so}"
if [ ! -f "$SCIANTIX_LIB" ]; then
  echo "[Allrun] WARNING: SCIANTIX_LIB='$SCIANTIX_LIB' not found; the fission_gas"
  echo "         coupling will fail to load. Rebuild a -DCOUPLING_TU lib (README.md):"
  echo "           g++ -O2 -std=c++17 -DCOUPLING_TU -fPIC -shared \\"
  echo "             \$(find include -type d | sed 's/^/-I/') \$(find src -name '*.C') \\"
  echo "             -o $SCIANTIX_LIB"
  echo "         (or 'export SCIANTIX_LIB=...' to a stable path before ./Allrun)."
fi

echo "Executing z3st..."
gmsh mesh.geo -2 > log_mesh.md
start=$SECONDS
Z3ST_PLAIN_LOG=1 python3 -m z3st > log_z3st.md
echo "z3st solve completed in $((SECONDS - start)) s  (solver log: log_z3st.md)"
python3 non-regression.py
python3 plots.py
