#!/bin/bash
cd "${0%/*}" || exit 1

./Allclean

# Skip mesh generation if mesh.msh is already up-to-date relative to mesh.geo.
# To force re-meshing, just `rm mesh.msh` before ./Allrun (or edit mesh.geo).
if [ ! -f mesh.msh ] || [ mesh.geo -nt mesh.msh ]; then
    echo "[Allrun] Generating 2D mesh from mesh.geo..."
    gmsh -2 mesh.geo -format msh2 > log_mesh.md
else
    echo "[Allrun] Reusing existing mesh.msh (mesh.geo unchanged since)."
fi

python3 -m z3st > log_z3st.md

python3 non-regression.py
